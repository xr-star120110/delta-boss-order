/**
 * 三角洲老板点单 - 首页样式
 * 军事硬核 + 赛博朋克风格
 */

/* ========== 页面容器 ========== */
.container {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* ========== 顶部标题区域 ========== */
.header {
  position: relative;
  padding: 80rpx 40rpx 60rpx;
  overflow: hidden;
}

/* 背景装饰 - 模拟军事扫描线效果 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(201, 169, 110, 0.08) 0%,
    rgba(10, 14, 20, 0) 50%,
    rgba(0, 230, 118, 0.03) 100%
  );
  /* 模拟扫描线 */
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 4rpx,
      rgba(0, 230, 118, 0.02) 4rpx,
      rgba(0, 230, 118, 0.02) 5rpx
    );
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 主标题 */
.header-title {
  font-size: 52rpx;
  font-weight: 900;
  color: #c9a96e;
  letter-spacing: 8rpx;
  text-shadow: 0 0 30rpx rgba(201, 169, 110, 0.4), 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  margin-bottom: 12rpx;
}

/* 英文副标题 */
.header-subtitle {
  font-size: 22rpx;
  color: rgba(0, 230, 118, 0.6);
  letter-spacing: 12rpx;
  font-weight: 300;
  margin-bottom: 30rpx;
}

/* 装饰分割线 */
.header-divider {
  display: flex;
  align-items: center;
  width: 80%;
  margin-bottom: 24rpx;
}

.divider-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(
    90deg,
    transparent 0%,
    #c9a96e 50%,
    transparent 100%
  );
}

.divider-icon {
  margin: 0 20rpx;
  font-size: 28rpx;
}

/* 描述文字 */
.header-desc {
  font-size: 26rpx;
  color: rgba(224, 224, 224, 0.6);
  letter-spacing: 4rpx;
}

/* ========== 分类卡片列表 ========== */
.category-list {
  padding: 30rpx 30rpx 0;
}

/* 分类卡片 */
.category-card {
  display: flex;
  align-items: center;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  position: relative;
  overflow: hidden;
  transition: all 0.3s ease;
}

/* 卡片左侧光效 */
.category-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  bottom: 20%;
  width: 4rpx;
  background: linear-gradient(180deg, transparent, #c9a96e, transparent);
  border-radius: 2rpx;
}

/* 卡片按压效果 */
.category-card:active {
  transform: scale(0.98);
  border-color: rgba(201, 169, 110, 0.4);
  box-shadow: 0 8rpx 40rpx rgba(201, 169, 110, 0.15);
}

/* 图标区域 */
.card-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(201, 169, 110, 0.08);
  border-radius: 24rpx;
  border: 1rpx solid rgba(201, 169, 110, 0.2);
  margin-right: 30rpx;
  flex-shrink: 0;
}

.card-icon {
  font-size: 52rpx;
}

/* 文字区域 */
.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.card-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #e0e0e0;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.card-desc {
  font-size: 24rpx;
  color: rgba(224, 224, 224, 0.5);
  letter-spacing: 2rpx;
}

/* 箭头 */
.card-arrow {
  flex-shrink: 0;
  margin-left: 20rpx;
}

.arrow-icon {
  font-size: 24rpx;
  color: rgba(201, 169, 110, 0.5);
}

/* ========== 打手入驻区域 ========== */
.join-section {
  padding: 20rpx 30rpx 0;
}

.join-divider {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.join-divider-text {
  font-size: 24rpx;
  color: rgba(0, 230, 118, 0.5);
  letter-spacing: 8rpx;
  margin: 0 20rpx;
  white-space: nowrap;
}

.join-card {
  display: flex;
  align-items: center;
  padding: 36rpx 30rpx;
  position: relative;
  overflow: hidden;
  border-color: rgba(0, 230, 118, 0.2) !important;
}

/* 入驻卡片左侧光效 - 荧光绿色调 */
.join-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 20%;
  bottom: 20%;
  width: 4rpx;
  background: linear-gradient(180deg, transparent, #00e676, transparent);
  border-radius: 2rpx;
}

.join-card:active {
  transform: scale(0.98);
  border-color: rgba(0, 230, 118, 0.5) !important;
  box-shadow: 0 8rpx 40rpx rgba(0, 230, 118, 0.1);
}

.join-icon-wrap {
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 230, 118, 0.06);
  border-radius: 24rpx;
  border: 1rpx solid rgba(0, 230, 118, 0.2);
  margin-right: 30rpx;
  flex-shrink: 0;
}

.join-icon {
  font-size: 52rpx;
}

.join-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.join-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #00e676;
  margin-bottom: 8rpx;
  letter-spacing: 4rpx;
}

.join-desc {
  font-size: 24rpx;
  color: rgba(224, 224, 224, 0.45);
  letter-spacing: 2rpx;
}

/* ========== 底部标语 ========== */
.footer-motto {
  padding: 60rpx 40rpx;
  text-align: center;
}

.motto-text {
  font-size: 24rpx;
  color: rgba(224, 224, 224, 0.3);
  letter-spacing: 4rpx;
  font-style: italic;
}
