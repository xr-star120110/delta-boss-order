/**
 * 三角洲老板点单 - 列表页样式
 */

/* ========== 页面容器 ========== */
.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ========== 顶部统计条 ========== */
.stats-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 30rpx;
  background: rgba(20, 26, 36, 0.6);
  border-bottom: 1rpx solid rgba(201, 169, 110, 0.1);
}

.stats-text {
  font-size: 24rpx;
  color: rgba(224, 224, 224, 0.5);
}

.stats-num {
  color: #c9a96e;
  font-weight: 700;
  font-size: 28rpx;
}

.stats-divider {
  width: 2rpx;
  height: 24rpx;
  background: rgba(201, 169, 110, 0.3);
  margin: 0 30rpx;
}

/* ========== 陪玩列表 ========== */
.player-list {
  padding: 20rpx 24rpx 0;
}

/* ========== 陪玩卡片 ========== */
.player-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
  position: relative;
  overflow: hidden;
}

/* 卡片左侧光条 */
.player-card::after {
  content: '';
  position: absolute;
  left: 0;
  top: 15%;
  bottom: 15%;
  width: 3rpx;
  background: linear-gradient(180deg, transparent, #00e676, transparent);
  border-radius: 2rpx;
  opacity: 0.5;
}

.player-card:active {
  transform: scale(0.985);
  border-color: rgba(0, 230, 118, 0.3);
}

/* ========== 头像区域 ========== */
.player-avatar-wrap {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.player-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(201, 169, 110, 0.4);
  box-shadow: 0 0 20rpx rgba(201, 169, 110, 0.2);
}

/* 在线状态点 */
.online-dot {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  width: 20rpx;
  height: 20rpx;
  background: #00e676;
  border-radius: 50%;
  border: 3rpx solid #0a0e14;
  box-shadow: 0 0 10rpx rgba(0, 230, 118, 0.6);
}

/* ========== 信息区域 ========== */
.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  overflow: hidden;
}

.info-row {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

/* 昵称 */
.player-nickname {
  font-size: 30rpx;
  font-weight: 700;
  color: #e0e0e0;
  margin-right: 12rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 荣誉勋章 */
.player-honor {
  font-size: 20rpx;
  color: #c9a96e;
  background: rgba(201, 169, 110, 0.1);
  border: 1rpx solid rgba(201, 169, 110, 0.25);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  white-space: nowrap;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 评分行 */
.rating-row {
  margin-bottom: 8rpx;
}

.rating-stars {
  font-size: 22rpx;
  margin-right: 4rpx;
  letter-spacing: -2rpx;
}

.rating-value {
  font-size: 24rpx;
  font-weight: 700;
  color: #c9a96e;
  margin-left: 6rpx;
}

/* 标签行 */
.tags-row {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.tag-item {
  font-size: 20rpx;
  color: rgba(0, 230, 118, 0.8);
  background: rgba(0, 230, 118, 0.08);
  border: 1rpx solid rgba(0, 230, 118, 0.2);
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
}

/* 评价预览 */
.review-preview {
  max-width: 100%;
}

.review-text {
  font-size: 22rpx;
  color: rgba(224, 224, 224, 0.45);
  font-style: italic;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* ========== 价格区域 ========== */
.player-price {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
}

.price-value {
  font-size: 38rpx;
  font-weight: 900;
  color: #c9a96e;
  text-shadow: 0 0 10rpx rgba(201, 169, 110, 0.3);
}

.price-unit {
  font-size: 20rpx;
  color: rgba(224, 224, 224, 0.5);
  margin-bottom: 6rpx;
}

.order-count {
  font-size: 20rpx;
  color: rgba(224, 224, 224, 0.35);
  margin-top: 4rpx;
}

/* ========== 加载更多 ========== */
.load-more {
  padding: 30rpx 0;
  text-align: center;
}

.load-text {
  font-size: 24rpx;
  color: rgba(224, 224, 224, 0.35);
  letter-spacing: 4rpx;
}
