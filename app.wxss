/**
 * 三角洲老板点单 - 全局样式
 * 设计风格：硬核军事 + 赛博朋克
 * 主色调：深色背景 #0a0e14，暗金 #c9a96e，荧光绿 #00e676
 */

/* ========== 全局重置 ========== */
page {
  background-color: #0a0e14;
  color: #e0e0e0;
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* ========== 通用容器 ========== */
.container {
  min-height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 赛博朋克发光文字 ========== */
.neon-text {
  color: #00e676;
  text-shadow: 0 0 10rpx rgba(0, 230, 118, 0.5);
}

/* ========== 暗金高亮文字 ========== */
.gold-text {
  color: #c9a96e;
}

/* ========== 磨砂玻璃卡片 ========== */
.glass-card {
  background: rgba(20, 26, 36, 0.85);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(201, 169, 110, 0.15);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.4);
}

/* ========== 通用按钮 ========== */
.btn-primary {
  background: linear-gradient(135deg, #c9a96e 0%, #a6844a 100%);
  color: #0a0e14;
  border: none;
  border-radius: 12rpx;
  font-weight: bold;
  font-size: 32rpx;
  padding: 20rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(201, 169, 110, 0.3);
  transition: all 0.2s ease;
}

.btn-primary:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* ========== 一像素边框工具类 ========== */
.border-b {
  border-bottom: 1rpx solid rgba(201, 169, 110, 0.1);
}

/* ========== 弹性布局工具 ========== */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* ========== 文字省略 ========== */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
